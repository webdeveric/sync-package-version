{
  "name": "@webdeveric/sync-package-version",
  "version": "0.3.0",
  "description": "Use your package.json version number in other files",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/webdeveric/sync-package-version.git"
  },
  "bugs": {
    "url": "https://github.com/webdeveric/sync-package-version/issues"
  },
  "homepage": "https://github.com/webdeveric/sync-package-version/#readme",
  "type": "module",
  "bin": {
    "sync-package-version": "bin/sync-package-version.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "spellcheck": "cspell --no-progress \"./{bin,src,test}/**/*.{js,json}\" \"./*.{md,js}\" \"./package.json\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest ./test",
    "test:trace": "node --trace-warnings --experimental-vm-modules ./node_modules/.bin/jest --detectOpenHandles ./test",
    "lint": "eslint ./bin ./src ./test --ext .mjs --fix"
  },
  "keywords": [
    "package.json",
    "version",
    "sync"
  ],
  "author": {
    "email": "eric@webdeveric.com",
    "name": "Eric King",
    "url": "http://webdeveric.com/"
  },
  "dependencies": {
    "@webdeveric/utils": "^0.5.2"
  },
  "devDependencies": {
    "@webdeveric/eslint-config": "^0.1.2",
    "cspell": "^5.3.12",
    "eslint": "^7.25.0",
    "jest": "^27.0.0-next.9",
    "mock-fs": "^4.14.0"
  }
}
