{
  "name": "@webdeveric/sync-package-version",
  "version": "0.7.0",
  "description": "Sync your package.json version number across other files",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/webdeveric/sync-package-version.git"
  },
  "bugs": {
    "url": "https://github.com/webdeveric/sync-package-version/issues"
  },
  "homepage": "https://github.com/webdeveric/sync-package-version/#readme",
  "bin": {
    "sync-package-version": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "exports": {
    ".": null,
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "prettier . --write",
    "validate": "validate-package-exports --check --info",
    "build": "./build.mjs",
    "postbuild": "pnpm validate",
    "typecheck": "tsc --noEmit && tsc -p ./tsconfig.project-files.json",
    "spellcheck": "cspell --no-progress \"./src/**/*.{ts,js,json}\" \"./*.{md,js,mjs}\" \"./LICENSE\" \"./package.json\"",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint ./src ./*.mjs --fix",
    "prepublishOnly": "pnpm typecheck && pnpm spellcheck && pnpm lint && pnpm coverage && pnpm build",
    "prepare": "husky"
  },
  "keywords": [
    "package.json",
    "version",
    "sync"
  ],
  "author": {
    "email": "eric@webdeveric.com",
    "name": "Eric King",
    "url": "http://webdeveric.com/"
  },
  "prettier": "@webdeveric/prettier-config",
  "dependencies": {
    "@webdeveric/utils": "^0.79.0",
    "commander": "^15.0.0",
    "semver": "^7.8.1"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@types/node": "^22.19.19",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@webdeveric/eslint-config-ts": "^0.12.0",
    "@webdeveric/prettier-config": "^0.4.0",
    "commitlint": "^21.0.2",
    "commitlint-plugin-cspell": "^0.9.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-clean": "^1.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "validate-package-exports": "^1.0.1",
    "vitest": "^4.1.8"
  }
}
